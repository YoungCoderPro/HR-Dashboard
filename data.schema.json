{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HR Compliance Dashboard data contract",
  "description": "The exact shape data.json must keep. The routine must not add or remove top-level sections or change key names/array shapes. Validated in CI before any PR can merge.",
  "type": "object",
  "required": ["meta", "minimumWage", "unemployment", "paidLeaveTable", "workersComp", "posters", "newsFeed", "scoreData", "eeoc", "paidLeaveMap"],
  "additionalProperties": false,
  "definitions": {
    "stateKey": {
      "type": "string",
      "pattern": "^(AL|AK|AZ|AR|CA|CO|CT|DE|FL|GA|HI|ID|IL|IN|IA|KS|KY|LA|ME|MD|MA|MI|MN|MS|MO|MT|NE|NV|NH|NJ|NM|NY|NC|ND|OH|OK|OR|PA|RI|SC|SD|TN|TX|UT|VT|VA|WA|WV|WI|WY|DC)$"
    },
    "urlOrNull": {
      "oneOf": [
        { "type": "string", "pattern": "^https?://" },
        { "type": "null" }
      ]
    }
  },
  "properties": {
    "meta": {
      "type": "object",
      "required": ["dataVersion", "lastUpdated", "unemploymentPeriod", "eeocPeriod"],
      "properties": {
        "dataVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "unemploymentPeriod": { "type": "string" },
        "eeocPeriod": { "type": "string" },
        "notes": { "type": "string" },
        "reviewNotes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "minimumWage": {
      "type": "object",
      "minProperties": 51,
      "maxProperties": 51,
      "propertyNames": { "$ref": "#/definitions/stateKey" },
      "additionalProperties": {
        "type": "array",
        "minItems": 4,
        "maxItems": 4,
        "items": [
          { "type": "number", "minimum": 0, "maximum": 50 },
          { "type": "string" },
          { "type": "string" },
          { "$ref": "#/definitions/urlOrNull" }
        ]
      }
    },
    "unemployment": {
      "type": "object",
      "minProperties": 51,
      "maxProperties": 51,
      "propertyNames": { "$ref": "#/definitions/stateKey" },
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "maxItems": 1,
        "items": [
          { "type": "number", "minimum": 0, "maximum": 30 }
        ]
      }
    },
    "paidLeaveTable": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["s", "a", "p", "f", "m", "y", "c", "u", "act"],
        "additionalProperties": false,
        "properties": {
          "s": { "type": "string" },
          "a": { "type": "string" },
          "p": { "type": "string" },
          "f": { "type": "number" },
          "m": { "type": "number" },
          "y": { "type": "number" },
          "c": { "type": "string" },
          "u": { "$ref": "#/definitions/urlOrNull" },
          "act": { "type": "boolean" }
        }
      }
    },
    "workersComp": {
      "type": "object",
      "minProperties": 51,
      "maxProperties": 51,
      "propertyNames": { "$ref": "#/definitions/stateKey" },
      "additionalProperties": {
        "type": "array",
        "minItems": 3,
        "maxItems": 3,
        "items": [
          { "type": "string" },
          { "type": "string" },
          { "$ref": "#/definitions/urlOrNull" }
        ]
      }
    },
    "posters": {
      "type": "object",
      "minProperties": 51,
      "maxProperties": 51,
      "propertyNames": { "$ref": "#/definitions/stateKey" },
      "additionalProperties": {
        "type": "object",
        "required": ["ag", "url", "ps"],
        "properties": {
          "ag": { "type": "string" },
          "url": { "$ref": "#/definitions/urlOrNull" },
          "ps": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["n", "r", "pdf"],
              "properties": {
                "n": { "type": "string" },
                "r": { "type": "string" },
                "pdf": { "$ref": "#/definitions/urlOrNull" }
              }
            }
          }
        }
      }
    },
    "newsFeed": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "date", "category", "priority", "iconBg", "icon", "title", "desc", "tags", "link", "linkLabel", "isNew"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "date": { "type": "string" },
          "category": { "type": "string", "enum": ["federal", "state", "market", "alert", "pfml"] },
          "priority": { "type": "string", "enum": ["high", "med", "info", "low"] },
          "iconBg": { "type": "string" },
          "icon": { "type": "string" },
          "title": { "type": "string" },
          "desc": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "link": { "$ref": "#/definitions/urlOrNull" },
          "linkLabel": { "type": "string" },
          "isNew": { "type": "boolean" }
        }
      }
    },
    "scoreData": {
      "type": "object",
      "minProperties": 51,
      "maxProperties": 51,
      "propertyNames": { "$ref": "#/definitions/stateKey" },
      "additionalProperties": {
        "type": "object",
        "required": ["mw", "pfml", "pt", "wc", "sl", "ad"],
        "additionalProperties": {
          "type": "object",
          "required": ["s", "v", "n", "c"],
          "properties": {
            "s": { "type": "number", "minimum": 0, "maximum": 100 },
            "v": { "type": "string" },
            "n": { "type": "string" },
            "c": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "eeoc": {
      "type": "object",
      "minProperties": 51,
      "maxProperties": 51,
      "propertyNames": { "$ref": "#/definitions/stateKey" },
      "additionalProperties": {
        "type": "object",
        "required": ["charges", "rate", "top", "note"],
        "properties": {
          "charges": { "type": "number" },
          "rate": { "type": "number" },
          "top": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    },
    "paidLeaveMap": {
      "type": "object",
      "propertyNames": { "$ref": "#/definitions/stateKey" },
      "additionalProperties": {
        "type": "object",
        "required": ["color", "label", "rate", "weeks", "contrib", "since"],
        "properties": {
          "color": { "type": "string" },
          "label": { "type": "string" },
          "rate": { "type": "string" },
          "weeks": { "type": "number" },
          "contrib": { "type": "string" },
          "since": { "type": "number" }
        }
      }
    }
  }
}
